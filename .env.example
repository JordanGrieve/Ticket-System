# ─────────────────────────────────────────────────────────────
# Postbox — environment variables
# Copy to .env.local and fill in. Never commit .env.local.
# ─────────────────────────────────────────────────────────────

# Neon Postgres (this product's OWN database, separate from any client site)
# https://neon.tech → Project → Connection string (pooled)
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# Clerk — one workspace login per client
# https://dashboard.clerk.com → API keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"
# Where Clerk sends users after auth (defaults are fine for App Router)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/"

# Resend — sends replies AND parses inbound email
# https://resend.com → API keys
RESEND_API_KEY="re_xxx"
# Shared secret used to verify the inbound webhook (set the same value in Resend)
INBOUND_WEBHOOK_SECRET="choose-a-long-random-string"

# Public URL of THIS app (used in the generated install snippet)
NEXT_PUBLIC_APP_URL="https://support.yourapp.com"

# Domain inbound customer email is routed to (per-ticket reply addresses)
INBOUND_EMAIL_DOMAIN="inbound.yourapp.com"
